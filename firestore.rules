rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Mesajlar koleksiyonu: Herkes oluşturabilir ama sadece adminler okuyabilir
    match /messages/{messageId} {
      allow create: if true; // Genel form gönderimi için açık
      
      // Sadece giriş yapmış ve admin olan kullanıcılar listeyi görebilir
      // (Custom claims veya admin listesi kontrolü eklenebilir)
      allow read, update, delete: if request.auth != null;
    }
    
    // Diğer tüm dokümanlar varsayılan olarak kapalı
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
