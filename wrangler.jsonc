{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "temizisyapi-website",
	"main": ".open-next/worker.js",
	"compatibility_date": "2024-09-26",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "NEXT_ASSETS"
	},
	"images": {
		"binding": "APP_IMAGES"
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"invocation_logs": true
		}
	}
}